/*
 * Trackpoint (PS/2 over UART) for martos05.
 *
 * Wiring:
 *   TP_DATA (SDA) → D0  (&pro_micro 0, P0.08)
 *   TP_CLK  (SCL) → D1  (&pro_micro 1, P0.06)
 *   No hardware reset line — relying on external POR circuit.
 *
 * Based on infused-kim's example zmk-config for the kb_zmk_ps2_mouse_
 * trackpoint_driver module.
 */

// --- User pin configuration --------------------------------------------------

// SCL = D1 (high-frequency pin, blue on nice!nano pinout)
#define MOUSE_PS2_PIN_SCL_PRO_MICRO <&pro_micro 1 GPIO_ACTIVE_HIGH>

// SDA = D0 (high-frequency pin, blue on nice!nano pinout)
#define MOUSE_PS2_PIN_SDA_PRO_MICRO <&pro_micro 0 GPIO_ACTIVE_HIGH>

// SDA in pinctrl notation — D0 = P0.08 on nice!nano v2
#define MOUSE_PS2_PIN_SDA_PINCTRL   <NRF_PSEL(UART_RX, 0, 8)>

// UART baud rate for PS/2 — 14400 matches standard IBM/Lenovo trackpoint
// clock (~14.5 kHz). Change only if logic-analyzer measurements differ.
#define MOUSE_PS2_UART_BAUD_RATE    <14400>

// Unexposed UART pins used as "parking" slots when the driver bit-bangs GPIO
// on the real SDA pin. Do NOT change these on nice!nano v2.
#define MOUSE_PS2_PIN_UNEXPOSED_TX  <NRF_PSEL(UART_TX, 0, 27)>
#define MOUSE_PS2_PIN_UNEXPOSED_RX  <NRF_PSEL(UART_RX, 0, 28)>


// --- Interrupt priority overrides (nice!nano v2) -----------------------------
//
// PS/2 must be serviced within ~30–50 us. BLE and default peripheral interrupts
// can block that long, which causes trackpoint lag and "sticky" movement.
// Promote GPIOTE to priority 0 and demote everything else to priority 3.

&gpiote     { interrupts = < 6 0 >; };
&clock      { interrupts = < 0 3 >; };
&power      { interrupts = < 0 3 >; };
&radio      { interrupts = < 1 3 >; };
&uart0      { interrupts = < 2 3 >; };
&i2c0       { interrupts = < 3 3 >; };
&spi0       { interrupts = < 3 3 >; };
&i2c1       { interrupts = < 4 3 >; };
&spi1       { interrupts = < 4 3 >; };
&nfct       { interrupts = < 5 3 >; };
&adc        { interrupts = < 7 3 >; };
&timer0     { interrupts = < 8 3 >; };
&timer1     { interrupts = < 9 3 >; };
&timer2     { interrupts = <10 3 >; };
&rtc0       { interrupts = <11 3 >; };
&temp       { interrupts = <12 3 >; };
&rng        { interrupts = <13 3 >; };
&ecb        { interrupts = <14 3 >; };
&ccm        { interrupts = <15 3 >; };
&wdt        { interrupts = <16 3 >; };
&rtc1       { interrupts = <17 3 >; };
&qdec       { interrupts = <18 3 >; };
&comp       { interrupts = <19 3 >; };
&egu0       { interrupts = <20 3 >; };
&egu1       { interrupts = <21 3 >; };
&egu2       { interrupts = <22 3 >; };
&egu3       { interrupts = <23 3 >; };
&egu4       { interrupts = <24 3 >; };
&egu5       { interrupts = <25 3 >; };
&timer3     { interrupts = <26 3 >; };
&timer4     { interrupts = <27 3 >; };
&pwm0       { interrupts = <28 3 >; };
&pdm0       { interrupts = <29 3 >; };
&pwm1       { interrupts = <33 3 >; };
&pwm2       { interrupts = <34 3 >; };
&spi2       { interrupts = <35 3 >; };
&rtc2       { interrupts = <36 3 >; };
&i2s0       { interrupts = <37 3 >; };
&usbd       { interrupts = <39 3 >; };
&uart1      { interrupts = <40 3 >; };
&qspi       { interrupts = <41 3 >; };
&pwm3       { interrupts = <45 3 >; };
&spi3       { interrupts = <47 3 >; };
&cryptocell { interrupts = <42 3 >; };


// --- Pinctrl states for uart0 in PS/2 mode -----------------------------------

&pinctrl {
    // Receive state: RX wired to the real SDA pin, TX parked on an
    // unexposed pin.
    uart0_ps2_default: uart0_ps2_default {
        group1 {
            psels = MOUSE_PS2_PIN_UNEXPOSED_TX,
                    MOUSE_PS2_PIN_SDA_PINCTRL;
        };
    };

    uart0_ps2_sleep: uart0_ps2_sleep {
        group1 {
            psels = MOUSE_PS2_PIN_UNEXPOSED_TX,
                    MOUSE_PS2_PIN_SDA_PINCTRL;
            low-power-enable;
        };
    };

    // Transmit state: both UART pins parked — the driver frees SDA for
    // GPIO bit-banging during PS/2 writes.
    uart0_ps2_off: uart0_ps2_off {
        group1 {
            psels = MOUSE_PS2_PIN_UNEXPOSED_TX,
                    MOUSE_PS2_PIN_UNEXPOSED_RX;
        };
    };
};


// --- uart0 reconfigured as PS/2 transport ------------------------------------

&uart0 {
    status = "okay";
    compatible = "nordic,nrf-uarte";

    current-speed = MOUSE_PS2_UART_BAUD_RATE;
    pinctrl-0 = <&uart0_ps2_default>;
    pinctrl-1 = <&uart0_ps2_off>;
    pinctrl-names = "default", "sleep";

    uart_ps2: uart_ps2 {
        status = "okay";
        compatible = "uart-ps2";
        scl-gpios = MOUSE_PS2_PIN_SCL_PRO_MICRO;
        sda-gpios = MOUSE_PS2_PIN_SDA_PRO_MICRO;
    };
};


// --- mouse_ps2 device + input listener ---------------------------------------

/ {
    mouse_ps2: mouse_ps2 {
        status = "okay";
        compatible = "zmk,input-mouse-ps2";
        ps2-device = <&uart_ps2>;
        // No rst-gpios — relying on external POR circuit for trackpoint init.
    };

    mouse_ps2_input_listener: mouse_ps2_input_listener {
        status = "okay";
        compatible = "zmk,input-listener-ps2";
        device = <&mouse_ps2>;

        // Physical trackpoint orientation: Y axis is flipped vs the driver's
        // expected convention — up/down come out swapped. X axis is fine.
        y-invert;
    };
};
